{{>header}}

{{>navigation}}

<div class="row">
  <div class="leftcolumn">
    <div class="card">
      <h2>Editors</h2>
      <p>Only editors should be able to view this page!</p>

      <h2>Users</h2>
      <table border="1">
        <tr>
          <th>Username</th>
          <th>Password</th>
          <th>Access Level</th>
          <th>Delete</th>
        </tr>
        {{#users}}
        <tr>
          <td>{{username}}</td>
          <td>{{password}}</td>
          <td>{{level}}</td>
          <td><a href="/editors/deleteUser/{{username}}">D</a></td>
        </tr>
        {{/users}}
      </table>

      <h2>Articles</h2>
      <table border="1">
        <tr>
          <th>Title</th>
          <th>Author</th>
          <th>Delete</th>
        </tr>
        {{#articles}}
        <tr>
          <td>{{title}}</td>
          <td>{{username}}</td>
          <td><a href="/editors/deleteArticle/{{title}}/{{username}}">D</a></td>
        </tr>
        {{/articles}}
      </table>

    </div>
  </div>

  {{>sidebar}}

</div>

{{>footer}}